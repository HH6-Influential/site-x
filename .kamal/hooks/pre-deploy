#!/usr/bin/env bash
set -euo pipefail

SSH_USER="adminops"
BASE_DIR="/srv/sites/site-x"
DIRS=(uploads tmp data logs)

# Rootless Docker maps container uids through the adminops subuid range.
# Container uid 1501 (siteuser) maps to host uid 167036 (165536 + 1501 - 1).
# Volume directories must be owned by this host uid to be writable by the container.
HOST_UID="167036"

IFS=',' read -ra HOSTS <<< "${KAMAL_HOSTS:-100.87.240.99}"

for host in "${HOSTS[@]}"; do
  echo "--- Preparing volume directories on $host"
  tailscale ssh "$SSH_USER@$host" bash <<EOF
    set -euo pipefail
    for dir in ${DIRS[@]}; do
      mkdir -p "$BASE_DIR/\$dir"
      chown $HOST_UID:$HOST_UID "$BASE_DIR/\$dir"
      chmod 750 "$BASE_DIR/\$dir"
    done
    echo "Done"
EOF
done