#!/usr/bin/env bash
set -euo pipefail

SSH_USER="adminops"
BASE_DIR="/srv/sites/site-x"
DIRS=(uploads tmp data logs)
APP_UID="1501"

IFS=',' read -ra HOSTS <<< "${KAMAL_HOSTS:-100.87.240.99}"

for host in "${HOSTS[@]}"; do
  echo "--- Setting ACLs on $host"
  tailscale ssh "$SSH_USER@$host" bash <<EOF
    set -euo pipefail
    for dir in ${DIRS[@]}; do
      mkdir -p "$BASE_DIR/\$dir"
      setfacl -m u:$APP_UID:rwX "$BASE_DIR/\$dir"
      setfacl -d -m u:$APP_UID:rwX "$BASE_DIR/\$dir"
    done
    echo "Done"
EOF
done